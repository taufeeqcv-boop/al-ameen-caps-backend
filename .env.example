# Canonical base URL (sitemap, meta, JSON-LD, PayFast return/cancel URLs)
# Production: https://alameencaps.com (primary; www redirects to apex in Netlify)
VITE_SITE_URL=https://alameencaps.com

# When frontend (alameencaps.com) and backend (al-ameen-caps-backend) are separate Netlify sites,
# set this on the FRONTEND site so Pre-orders and PayFast ITN work:
# VITE_FUNCTIONS_BASE=https://al-ameen-caps-backend.netlify.app

# Delivery fee in ZAR (checkout and shipping). Default 99 if unset.
VITE_DELIVERY_FEE=99

# PAYFAST — production: live URL + live credentials (see PayFast dashboard)
# Sandbox: set VITE_PAYFAST_SANDBOX=true and use sandbox merchant ID/key/passphrase
VITE_PAYFAST_SANDBOX=false
VITE_PAYFAST_MERCHANT_ID=...
VITE_PAYFAST_MERCHANT_KEY=...
# Live process URL (production uses netlify.toml; match locally if testing live checkout)
VITE_PAYFAST_LIVE_PROCESS_URL=https://payment.payfast.io/eng/process
# Must match PAYFAST_PASSPHRASE on Netlify (form signature + ITN validation)
VITE_PAYFAST_PASSPHRASE=...

# YOCO — server only (Payment Gateway secret sk_test_/sk_live_ from app.yoco.com → Payment gateway)
# YOCO_SECRET_KEY=sk_live_...
# Webhook signing secret (whsec_...) from Yoco when you register https://alameencaps.com/.netlify/functions/yoco-webhook
# YOCO_WEBHOOK_SECRET=whsec_...
# Optional: set true on a staging Netlify deploy to log pre-MD5 signature string (passphrase redacted) in the browser console. Never enable on production.
# VITE_PAYFAST_DEBUG=true

# SUPABASE (optional)
# VITE_SUPABASE_URL=...
# VITE_SUPABASE_ANON_KEY=...

# CONTACT FORM (optional). Use Formspree URL: https://formspree.io/f/your-form-id
# VITE_CONTACT_FORM_ACTION=https://formspree.io/f/xxxxxxxx
# VITE_CONTACT_EMAIL=sales@alameencaps.com

# --- GSC "Caps" position check (scripts/gsc-check-caps-position.js) ---
# Service account with Search Console "Full" on https://alameencaps.com
# GSC_CLIENT_EMAIL=...@....iam.gserviceaccount.com
# GSC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- IndexNow (build: scripts/write-indexnow-key.js) ---
# Set in Netlify Build & deploy > Environment so the key file is written to dist/ for Bing/IndexNow.
# INDEXNOW_KEY=4ed08a1ef99a4e2c900e1f0cd2eb69f8

# --- Merchant Center API (scripts/merchant-center-upload-products.js) ---
# Only if you use "Add products using API" in Merchant Center. See docs/MERCHANT_CENTER_API.md.
# MERCHANT_ID=123456789
# CONTENT_API_ACCESS_TOKEN=ya29....

# --- Netlify (server-side only: set in Netlify Dashboard) ---
# PAYFAST_MERCHANT_ID / PAYFAST_MERCHANT_KEY — same values as VITE_PAYFAST_* (initiate-payment)
# PAYFAST_PASSPHRASE — same as VITE_PAYFAST_PASSPHRASE and PayFast dashboard passphrase
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_password
# ADMIN_EMAIL=admin_email@gmail.com
# VITE_SITE_URL or VITE_APP_URL — base URL for ITN email contact link
# ORDER_CONFIRMATION_SECRET — optional; required by send-order-confirmation and send-review-request
# REVIEW_COUPON_CODE — optional; code shown after review (default REVIEW5). Create this code in your payment/discount system.

# --- Digital Majlis thank-you email (Netlify function + Supabase webhook) ---
# See docs/MAJLIS_THANK_YOU_WEBHOOK.md. Set in Netlify + add Database Webhook in Supabase.
# MAJLIS_WEBHOOK_SECRET=...  # optional; add as X-Webhook-Secret header in webhook
# MAJLIS_SENDER_EMAIL=taufeeqcv@gmail.com  # optional; defaults to EMAIL_USER

# --- Post-purchase review automation (scripts/send-review-requests.js + GitHub Action) ---
# Set in GitHub repo Secrets for .github/workflows/order-maintenance.yml (runs daily 10:00 SAST)
# EMAIL_USER=...
# EMAIL_PASS=...
# SUPABASE_URL=... or VITE_SUPABASE_URL=...
# SUPABASE_SERVICE_ROLE_KEY=...
